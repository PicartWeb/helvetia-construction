Options -Indexes
DirectoryIndex index.html

ErrorDocument 404 /bau/404.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /bau/

  # Force HTTPS.
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # Redirect old HTML URLs to clean URLs.
  RewriteRule ^index\.html$ /bau/ [R=301,L]
  RewriteRule ^services\.html$ /bau/leistungen [R=301,L]
  RewriteRule ^projects\.html$ /bau/projekte [R=301,L]
  RewriteRule ^about\.html$ /bau/ueber-uns [R=301,L]
  RewriteRule ^contact\.html$ /bau/kontakt [R=301,L]
  RewriteRule ^impressum\.html$ /bau/impressum [R=301,L]
  RewriteRule ^datenschutz\.html$ /bau/datenschutz [R=301,L]

  # Clean URL routes.
  RewriteRule ^leistungen/?$ services.html [L]
  RewriteRule ^projekte/?$ projects.html [L]
  RewriteRule ^ueber-uns/?$ about.html [L]
  RewriteRule ^kontakt/?$ contact.html [L]
  RewriteRule ^impressum/?$ impressum.html [L]
  RewriteRule ^datenschutz/?$ datenschutz.html [L]
</IfModule>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=()"

  <FilesMatch "\.(?:css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(?:png|jpe?g|gif|webp|svg|ico|avif|woff2?|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(?:html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/otf "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript text/javascript
  AddOutputFilterByType DEFLATE application/json application/xml image/svg+xml
</IfModule>
